    # Backend API Base URL
    EXPO_PUBLIC_API_BASE_URL=your-backend-url-here

    # Google Maps API Key
    VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

    # Viewer Default Credentials
    EXPO_PUBLIC_VIEWER_EMAIL=view@your_group.com
    EXPO_PUBLIC_VIEWER_PASSWORD=MyAwesomeSecretPassword